rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Land rates - readable by anyone
    match /landRates/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    
    // Users collection
    match /users/{phone} {
      allow read, write: if true;
    }

    // Digital Twins
    match /digitalTwins/{landId} {
      allow read, write: if true;
    }

    // Blockchain - readable by anyone, writable by backend
    match /blockchain/{blockId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
