rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Land rates - readable by anyone, writable only by Cloud Functions (admin)
    match /landRates/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    
    // Users collection
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
